# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Copia questo file in .env.local e compila con i tuoi valori.
# Su Vercel aggiungile in: Project → Settings → Environment Variables
#
# Stringa di connessione Neon (Dashboard → Connection Details → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Segreto per firmare i token JWT (minimo 32 caratteri, casuale).
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_questa_stringa_con_una_random_di_almeno_48_caratteri

# ─── Auth admin (PIN per accesso rapido) ──────────────────────────────────────
# PIN mostrato ai corridori per accedere all'admin (cambia a piacere).
VITE_ADMIN_PIN=gratitude2026

# ─── Google Maps (routing percorso admin) ────────────────────────────────────
# Richiede "Directions API" e "Geocoding API" attive su Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# ─── Geoapify (mappa statica per post social) ────────────────────────────────
# Gratuito fino a 3.000 req/giorno — https://www.geoapify.com
VITE_GEOAPIFY_API_KEY=your_geoapify_api_key_here

# ─── Stripe (pagamenti iscrizioni) ───────────────────────────────────────────
# Chiave pubblica usata nel frontend per Stripe.js / Checkout
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Chiave segreta usata nelle API routes Vercel (NON nel frontend)
STRIPE_SECRET_KEY=sk_live_...

# ─── PayPal (donazioni) ────────────────────────────────────────────────────
# Client ID e Secret da developer.paypal.com → Apps & Credentials
# VITE_PAYPAL_CLIENT_ID è lo stesso valore di PAYPAL_CLIENT_ID (serve al frontend)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_secret_here
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
# Imposta "live" per produzione, default = sandbox
PAYPAL_ENV=sandbox
