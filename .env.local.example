# ─── Supabase ────────────────────────────────────────────────────────────────
# Copia questo file in .env.local e compila con i tuoi valori Supabase.
# Su Vercel aggiungile in: Project → Settings → Environment Variables

VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Auth admin (PIN + credenziali Supabase per RLS) ─────────────────────────
# PIN mostrato ai corridori per accedere all'admin (cambia a piacere).
VITE_ADMIN_PIN=gratitude2026
# Email e password dell'account Supabase admin (usati in background per i
# permessi di scrittura GPS — non visibili nel form di login).
VITE_ADMIN_EMAIL=admin@tuodominio.it
VITE_ADMIN_PASS=latuapasswordsupabase

# ─── Stripe (pagamenti iscrizioni) ───────────────────────────────────────────
# Necessario per abilitare i pagamenti online con carta.
# Ottieni le chiavi da: https://dashboard.stripe.com/apikeys
#
# NOTA: la chiave segreta (STRIPE_SECRET_KEY) va aggiunta nei Secrets
#       della Supabase Edge Function (NON qui), mai nel frontend.
#
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...    ← chiave pubblica (frontend-safe)
